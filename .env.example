# AI Copilot 环境变量模板
#
# ⚠️ 必须保持 LF 换行符。CRLF 会让 API key 末尾混入 \r,
# 触发 httpx 报 "Illegal header value"。
# 编辑后请用 `file .env` 检查, 输出应显示 "ASCII text"。
#
# 把本文件复制为 .env 后填入真实值:
#   cp .env.example .env

# === LLM ===
# MiniMax (OpenAI 兼容) 鉴权 key
MINIMAX_API_KEY=

# === Database ===
# runtime: asyncpg; alembic 自动替换为 psycopg2
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/db_name

# === Cache / Task Queue ===
# 缓存 + (P1 之后) Celery broker/backend
REDIS_URL=redis://:password@127.0.0.1:6379/0

# === Embedding ===
# sentence-transformers 拉模型用的镜像, 国内建议 hf-mirror
HF_ENDPOINT=https://hf-mirror.com

# === Dev flags ===
# 调试期打开, 会打印 SQL
DB_ECHO=False

# true 时 LLM 不发请求, 返回 mock, 方便离线 / CI 跑端到端
LLM_MOCK=False
